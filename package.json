{
  "name": "vitepress-plugin-depthindex",
  "version": "1.0.0",
  "description": "On-device intelligence layer for VitePress documentation",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "require": "./dist/client.js",
      "import": "./dist/client.mjs"
    }
  },
  "files": [
    "dist",
    "client.d.ts"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/client/index-loader.ts src/client/search-engine.ts src/client/query-processor.ts src/client/cloud-adapter.ts src/client/personalization.ts src/client/pwa-handler.ts --dts --format esm,cjs --external vue,vitepress",
    "dev": "tsup src/index.ts --watch",
    "test": "vitest run",
    "docs:dev": "vitepress dev docs",
    "docs:build": "npm run build && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "vitepress",
    "search",
    "ai",
    "documentation",
    "on-device",
    "offline",
    "pwa"
  ],
  "author": "Eldrex Delos Reyes Bula <eldrexdelosreyesbula@gmail.com>",
  "license": "MIT",
  "homepage": "https://depthindex.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EldrexDelosReyesBula/vitepress-depthindex.git"
  },
  "bugs": {
    "url": "https://github.com/EldrexDelosReyesBula/vitepress-depthindex/issues"
  },
  "peerDependencies": {
    "vitepress": "^1.0.0",
    "vue": "^3.3.0"
  },
  "dependencies": {
    "lz-string": "^1.5.0",
    "minisearch": "^6.3.0",
    "stemmer": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vue/compiler-sfc": "^3.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitepress": "^1.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.3.0"
  },
  "type": "module"
}
